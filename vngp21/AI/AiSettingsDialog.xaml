<mah:MetroWindow x:Class="vietnamgiapha.AI.AiSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Cài đặt AI"
        Height="540"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Blue.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#2E5FA3"/>
                <Setter Property="Margin" Value="0,12,0,4"/>
            </Style>
            <Style x:Key="GuideText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="#555"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="🤖" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Cài đặt AI" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Kích hoạt -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="Trạng thái"/>
                <CheckBox x:Name="enabledCheck" Content="Bật tính năng AI" Margin="0,0,0,4"
                          Checked="EnabledCheck_Changed" Unchecked="EnabledCheck_Changed"/>

                <!-- Chế độ hoạt động -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="Chế độ"/>
                <Border Background="#F5F9F5" CornerRadius="4" BorderBrush="#B8D8B8"
                        BorderThickness="1" Padding="10,8" Margin="0,0,0,4">
                    <StackPanel>
                        <RadioButton x:Name="localModeRadio" GroupName="AiMode" Margin="0,0,0,6"
                                     Checked="ModeRadio_Changed" Unchecked="ModeRadio_Changed">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="📚 Tra cứu nội bộ (không cần API key)"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="Tìm kiếm và trả lời dựa trên dữ liệu gia phả có sẵn."
                                           Style="{StaticResource GuideText}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="apiModeRadio" GroupName="AiMode"
                                     Checked="ModeRadio_Changed" Unchecked="ModeRadio_Changed">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="🤖 AI API (Gemini, Groq…)"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="Hỏi đáp tự nhiên qua API — cần internet và API key."
                                           Style="{StaticResource GuideText}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- Phần API — chỉ hiện khi chọn chế độ AI API -->
                <StackPanel x:Name="apiSettingsPanel">

                <!-- Nhà cung cấp -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="Nhà cung cấp"/>
                <ComboBox x:Name="providerCombo" Height="32" Margin="0,0,0,4"
                          SelectionChanged="ProviderCombo_SelectionChanged"/>

                <!-- Hướng dẫn lấy key -->
                <Border x:Name="guideBorder" Background="#F0F6FF" CornerRadius="4"
                        BorderBrush="#B8D0F0" BorderThickness="1" Padding="10,8" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock x:Name="guideText" Style="{StaticResource GuideText}"
                                   Text="Chọn nhà cung cấp để xem hướng dẫn."/>
                        <Button x:Name="openUrlBtn" Content="🌐 Mở trang lấy API key"
                                HorizontalAlignment="Left" Padding="8,4"
                                Click="OpenUrlBtn_Click" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- API Key -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="API Key"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="apiKeyBox" Grid.Column="0" Height="32"
                                 PasswordChar="●" Margin="0,0,4,0"
                                 PasswordChanged="ApiKeyBox_PasswordChanged"/>
                    <Button Grid.Column="1" x:Name="showKeyBtn" Content="👁" Width="36" Height="32"
                            ToolTip="Hiện / ẩn key" Click="ShowKeyBtn_Click"/>
                </Grid>
                <!-- Ô text hiển thị key khi bấm 👁 -->
                <TextBox x:Name="apiKeyVisible" Height="32" Margin="0,0,0,4"
                         Visibility="Collapsed" TextChanged="ApiKeyVisible_TextChanged"/>

                <!-- Model — IsEditable cho phép gõ tay model ID tùy ý -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="Model"/>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="modelCombo" Grid.Column="0" Height="32"
                              IsEditable="True" Margin="0,0,4,0"/>
                    <Button x:Name="refreshModelsBtn" Grid.Column="1"
                            Content="🔄" Width="36" Height="32"
                            ToolTip="Tải danh sách model mới nhất từ API"
                            Click="RefreshModelsBtn_Click"/>
                </Grid>
                <TextBlock x:Name="modelsStatusText" FontSize="10" Foreground="Gray"
                           Margin="2,0,0,8" Text="📋 Danh sách mặc định"/>

                <!-- Kiểm tra kết nối -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Button x:Name="testBtn" Content="🔍 Kiểm tra kết nối" Padding="10,6"
                            Click="TestBtn_Click" IsEnabled="False"/>
                    <TextBlock x:Name="testResultText" VerticalAlignment="Center"
                               Margin="10,0,0,0" TextWrapping="Wrap" MaxWidth="280"/>
                </StackPanel>

                <!-- Kết quả test đầy đủ -->
                <Border x:Name="testDetailBorder" Visibility="Collapsed"
                        Background="#F8F8F8" CornerRadius="4"
                        BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,4,0,0">
                    <TextBox x:Name="testDetailText" IsReadOnly="True" TextWrapping="Wrap"
                             BorderThickness="0" Background="Transparent"
                             FontSize="11" MaxHeight="80"/>
                </Border>

                </StackPanel>
                <!-- /apiSettingsPanel -->

            </StackPanel>
        </ScrollViewer>

        <!-- Nút OK / Hủy -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="saveBtn" Content="Lưu" Width="90" Height="34"
                    Margin="0,0,8,0" Click="SaveBtn_Click" IsDefault="True"/>
            <Button Content="Hủy" Width="90" Height="34"
                    Click="CancelBtn_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
