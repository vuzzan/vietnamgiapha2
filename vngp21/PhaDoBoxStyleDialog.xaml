<mah:MetroWindow x:Class="vietnamgiapha.PhaDoBoxStyleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Chỉnh ô gia đình"
        Height="640"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinHeight="520"
        MinWidth="480"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Orange.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Background" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="fillColorCombo" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                      Margin="6 0 0 8" DisplayMemberPath="Label"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Người chính" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="mainFontCombo" Grid.Row="1" Grid.Column="1" Margin="6 0 4 6"/>
            <TextBox x:Name="mainSizeBox" Grid.Row="1" Grid.Column="2" Margin="0 0 4 6" MaxLength="5"
                     mah:TextBoxHelper.Watermark="pt"/>
            <ComboBox x:Name="mainColorCombo" Grid.Row="1" Grid.Column="3" Margin="0 0 0 6" DisplayMemberPath="Label"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Người phụ" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="spouseFontCombo" Grid.Row="2" Grid.Column="1" Margin="6 0 4 8"/>
            <TextBox x:Name="spouseSizeBox" Grid.Row="2" Grid.Column="2" Margin="0 0 4 8" MaxLength="5"
                     mah:TextBoxHelper.Watermark="pt"/>
            <ComboBox x:Name="spouseColorCombo" Grid.Row="2" Grid.Column="3" Margin="0 0 0 8" DisplayMemberPath="Label"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Khung SVG" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="svgFrameCombo" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="6 0 0 8"
                      DisplayMemberPath="Display"
                      SelectionChanged="SvgFrameCombo_SelectionChanged"
                      ToolTip="family_*.svg trong thư mục ZoneSvg, khung lưu trong file gia phả, hoặc tạo khung mới"/>

            <StackPanel x:Name="newSvgPanel" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Visibility="Collapsed">
                <TextBlock Text="Tạo khung mới — dán hoặc tải file .svg" FontWeight="SemiBold" Margin="0 0 0 4"/>
                <TextBox x:Name="customSvgBox"
                         MinHeight="80" MaxHeight="120" Margin="0 0 0 4"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         mah:TextBoxHelper.Watermark="Dán &lt;svg&gt;... — tự kiểm tra và xem trước"/>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 4">
                    <Button Content="Tải file SVG" Width="95" Margin="0 0 8 0" Click="LoadSvgFromFile_Click"
                            ToolTip="Chọn file .svg trên máy"/>
                    <Button Content="Kiểm tra lại" Width="90" Margin="0 0 8 0" Click="ValidateSvg_Click"/>
                    <Button Content="Xóa nội dung" Width="90" Margin="0 0 8 0" Click="ClearSvg_Click"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Xem trước" VerticalAlignment="Top" FontWeight="SemiBold" Margin="0 4 0 0"/>
            <Border Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" x:Name="svgPreviewBorder"
                    Margin="6 0 0 0" Height="140" BorderBrush="#CCC" BorderThickness="1" Background="#FAFAFA">
                <Grid x:Name="svgPreviewHost" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="svgStatusText" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4"
                       Margin="0 4 0 8" TextWrapping="Wrap" Foreground="Gray"/>

            <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Apply Box" Width="100" Margin="0 0 8 0" Click="ApplyBox_Click" IsDefault="True"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                        ToolTip="Áp dụng lên ô đang chọn (xem trước, không đóng)"/>
                <Button Content="Apply All Box In Level" Width="150" Margin="0 0 8 0" Click="ApplyLevel_Click"
                        ToolTip="Áp dụng cho mọi ô cùng đời (xem trước, không đóng)"/>
                <Button Content="Close" Width="72" IsCancel="True" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</mah:MetroWindow>
