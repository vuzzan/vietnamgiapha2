<mah:MetroWindow x:Class="vietnamgiapha.PhaDoTitleStyleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Chỉnh khối tiêu đề phả đồ"
        Height="680"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinHeight="560"
        MinWidth="480"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Orange.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0 0 0 8" Foreground="Gray"
                       Text="Để trống dòng chữ = lấy từ tab thông tin gia phả. Khung SVG dùng chung catalog với ô gia đình."/>

            <TextBlock Grid.Row="1" Text="Dòng 1 — Tiêu đề gia phả" FontWeight="SemiBold" Margin="0 0 0 4"/>
            <TextBox x:Name="line1TextBox" Grid.Row="2" Margin="0 0 0 6" MaxLength="256"
                     mah:TextBoxHelper.Watermark="Mặc định: tên gia phả"/>

            <TextBlock Grid.Row="3" Text="Dòng 2 — Ở tại (OTAI)" FontWeight="SemiBold" Margin="0 0 0 4"/>
            <TextBox x:Name="line2TextBox" Grid.Row="4" Margin="0 0 0 8" MaxLength="256"
                     mah:TextBoxHelper.Watermark="Mặc định: RF_OTAI"/>

            <Grid Grid.Row="5" Margin="0 0 0 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nền" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="fillColorCombo" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                          Margin="6 0 0 6" DisplayMemberPath="Label"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Font dòng 1" VerticalAlignment="Center"/>
                <ComboBox x:Name="line1FontCombo" Grid.Row="1" Grid.Column="1" Margin="6 4 4 4"/>
                <TextBox x:Name="line1SizeBox" Grid.Row="1" Grid.Column="2" Margin="0 4 4 4" MaxLength="5"
                         mah:TextBoxHelper.Watermark="pt"/>
                <ComboBox x:Name="line1ColorCombo" Grid.Row="1" Grid.Column="3" Margin="0 4 0 4" DisplayMemberPath="Label"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Font dòng 2" VerticalAlignment="Center"/>
                <ComboBox x:Name="line2FontCombo" Grid.Row="2" Grid.Column="1" Margin="6 0 4 0"/>
                <TextBox x:Name="line2SizeBox" Grid.Row="2" Grid.Column="2" Margin="0 0 4 0" MaxLength="5"
                         mah:TextBoxHelper.Watermark="pt"/>
                <ComboBox x:Name="line2ColorCombo" Grid.Row="2" Grid.Column="3" DisplayMemberPath="Label"/>
            </Grid>

            <TextBlock Grid.Row="6" Text="Khung SVG" FontWeight="SemiBold" Margin="0 0 0 4"/>
            <ComboBox x:Name="svgFrameCombo" Grid.Row="7" Margin="0 0 0 6"
                      DisplayMemberPath="Display"
                      SelectionChanged="SvgFrameCombo_SelectionChanged"
                      ToolTip="title_*.svg trong thư mục ZoneSvg, khung lưu trong file gia phả, hoặc tạo khung mới"/>

            <StackPanel x:Name="newSvgPanel" Grid.Row="8" Visibility="Collapsed" Margin="0 0 0 6">
                <TextBlock Text="Tạo khung mới — dán hoặc tải file .svg" FontWeight="SemiBold" Margin="0 0 0 4"/>
                <TextBox x:Name="customSvgBox"
                         MinHeight="72" MaxHeight="110" Margin="0 0 0 4"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         mah:TextBoxHelper.Watermark="Dán &lt;svg&gt;..."/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Tải file SVG" Width="95" Margin="0 0 8 0" Click="LoadSvgFromFile_Click"/>
                    <Button Content="Kiểm tra lại" Width="90" Margin="0 0 8 0" Click="ValidateSvg_Click"/>
                    <Button Content="Xóa nội dung" Width="90" Click="ClearSvg_Click"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="9" Text="Xem trước khung" FontWeight="SemiBold" Margin="0 4 0 4"/>
            <Border Grid.Row="10" x:Name="svgPreviewBorder" Height="120" BorderBrush="#CCC" BorderThickness="1" Background="#FAFAFA">
                <Grid x:Name="svgPreviewHost" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="svgStatusText" Grid.Row="11" Margin="0 6 0 8" TextWrapping="Wrap" Foreground="Gray"/>

            <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Áp dụng" Width="90" Margin="0 0 8 0" Click="Apply_Click" IsDefault="True"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"/>
                <Button Content="Đóng" Width="72" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</mah:MetroWindow>
