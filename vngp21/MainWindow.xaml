                                            </StackPanel>
                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}" Margin="0,0,0,8">
                                                <ComboBox x:Name="phaDoSubtreeListBox"
                                                          Style="{StaticResource PhaDoScopeIconComboBoxStyle}"
                                                          Width="36" Height="36"
                                                          MaxDropDownHeight="360"
                                                          DisplayMemberPath="Label"
                                                          SelectionChanged="PhaDoSubtreeListBox_SelectionChanged"
                                                          ToolTip="Chọn Toàn phả hoặc phả con để vẽ"/>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Phạm vi vẽ"/>
                                            </StackPanel>

                                            <Rectangle Height="1" Fill="#D0D8E8" Margin="0,0,0,8"/>

                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}" Margin="0,0,0,8">
                                                <ComboBox x:Name="phaDoCardLayoutCombo"
                                                          Style="{StaticResource PhaDoCardLayoutIconComboBoxStyle}"
                                                          Width="36" Height="36"
                                                          MaxDropDownHeight="120"
                                                          DisplayMemberPath="Label"
                                                          SelectionChanged="PhaDoCardLayoutCombo_SelectionChanged"
                                                          ToolTip="Kiểu chữ trong ô gia đình"/>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Kiểu chữ"/>
                                            </StackPanel>

                                            <Rectangle Height="1" Fill="#D0D8E8" Margin="0,0,0,8"/>

                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}">
                                                <Button Style="{StaticResource PhaDoToolboxAccentRoundButtonStyle}"
                                                        Click="Button_Click_1" ToolTip="Vẽ lại phả đồ">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"/>
                                                </Button>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Vẽ lại"/>
                                            </StackPanel>
                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}">
                                                <Button Style="{StaticResource PhaDoToolboxIconButtonStyle}"
                                                        Click="ExportPhaDoSvg_Click"
                                                        ToolTip="Xuất phả đồ vector (.svg)">
                                                    <TextBlock Text="SVG" FontSize="11" FontWeight="Bold"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Button>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Xuất SVG"/>
                                            </StackPanel>
                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}" Margin="0,0,0,8">
                                                <Button Style="{StaticResource PhaDoToolboxIconButtonStyle}"
                                                        Click="PhaDoTitleStyle_Click"
                                                        ToolTip="Chỉnh khối tiêu đề (tên gia phả + ở tại)">
                                                    <TextBlock Text="&#xE736;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                                </Button>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Tiêu đề"/>
                                            </StackPanel>

                                            <Rectangle Height="1" Fill="#D0D8E8" Margin="0,0,0,8"/>

                                            <!-- Nhóm mode tương tác: Select hoặc Pan (kéo canvas) -->
                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}">
                                                <ToggleButton x:Name="phaDoSelectModeBtn"
                                                              Style="{StaticResource PhaDoToolboxToggleButtonStyle}"
                                                              IsChecked="True"
                                                              Click="PhaDoSelectModeBtn_Click"
                                                              ToolTip="Chế độ chọn — click chọn box, kéo di chuyển box">
                                                    <TextBlock Text="&#xE962;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                                </ToggleButton>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Chọn"/>
                                            </StackPanel>
                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}" Margin="0,0,0,8">
                                                <ToggleButton x:Name="phaDoPanModeBtn"
                                                              Style="{StaticResource PhaDoToolboxToggleButtonStyle}"
                                                              IsChecked="False"
                                                              Click="PhaDoPanModeBtn_Click"
                                                              ToolTip="Chế độ kéo canvas — giữ chuột trái kéo để cuộn phả đồ">
                                                    <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                                </ToggleButton>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Kéo canvas"/>
                                            </StackPanel>

                                            <Rectangle Height="1" Fill="#D0D8E8" Margin="0,0,0,8"/>

                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}">
                                                <Button Style="{StaticResource PhaDoToolboxIconButtonStyle}"
                                                        Click="PhaDoZoomIn_Click"
                                                        ToolTip="Phóng to (Ctrl + lăn chuột)">
                                                    <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                                </Button>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Phóng to"/>
                                            </StackPanel>
                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}">
                                                <Button Style="{StaticResource PhaDoToolboxIconButtonStyle}"
                                                        Click="PhaDoZoomOut_Click"
                                                        ToolTip="Thu nhỏ (Ctrl + lăn chuột)">
                                                    <TextBlock Text="&#xE71F;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                                </Button>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Thu nhỏ"/>
                                            </StackPanel>
                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}" Margin="0,0,0,8">
                                                <Button x:Name="phaDoZoomResetBtn" Style="{StaticResource PhaDoToolboxIconButtonStyle}"
                                                        Click="PhaDoZoomReset_Click"
                                                        ToolTip="Zoom 100%">
                                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                                </Button>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Zoom 100%"/>
                                            </StackPanel>

                                            <StackPanel Style="{StaticResource PhaDoToolboxRowStyle}">
                                                <Button x:Name="phaDoFullscreenBtn" Style="{StaticResource PhaDoToolboxIconButtonStyle}"
                                                        Click="PhaDoFullscreenToggle_Click" ToolTip="Toàn màn hình (F11)">
                                                    <TextBlock x:Name="phaDoFullscreenIcon" Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                                </Button>
                                                <TextBlock Tag="ToolboxCaption" Style="{StaticResource PhaDoToolboxCaptionStyle}" Text="Toàn màn hình"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <!-- Cột phải: toolbar ngữ cảnh + vùng vẽ -->
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Thanh công cụ luôn hiện — font size, Bold/Normal + 4 SVG zone -->
                                    <Border x:Name="phaDoContextToolbar" Grid.Row="0"
                                            Background="#F0F4FA" BorderBrush="#CDD6E8" BorderThickness="0,0,0,1"
                                            Padding="8,5">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                            <!-- Nhóm Font — active khi chọn Đời X hoặc dòng tiêu đề -->
                                            <StackPanel x:Name="phaDoCtxFontGroup" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Opacity="0.4">
                                                <TextBlock Text="Font:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                                                <ComboBox x:Name="phaDoCtxFontFamilyCombo" Width="150" Height="26"
                                                          mah:ControlsHelper.CornerRadius="5"
                                                          VerticalContentAlignment="Center"
                                                          VerticalAlignment="Center" Margin="0,0,8,0"
                                                          SelectionChanged="PhaDoCtxFontFamilyCombo_SelectionChanged"
                                                          ToolTip="Chọn font (áp dụng khi bấm Áp dụng)"/>
                                                <TextBlock Text="Cỡ:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                                                <TextBox x:Name="phaDoCtxFontSizeBox" Width="48" Height="26"
                                                         mah:ControlsHelper.CornerRadius="5"
                                                         VerticalContentAlignment="Center"
                                                         VerticalAlignment="Center" Margin="0,0,2,0"
                                                         PreviewMouseWheel="PhaDoCtxFontSizeBox_PreviewMouseWheel"/>
                                                <StackPanel Orientation="Vertical" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <Button Width="18" Height="12" Padding="0" Content="▲"
                                                            Click="PhaDoCtxFontSizeUp_Click"
                                                            ToolTip="Tăng cỡ chữ"/>
                                                    <Button Width="18" Height="12" Padding="0" Content="▼"
                                                            Click="PhaDoCtxFontSizeDown_Click"
                                                            ToolTip="Giảm cỡ chữ"/>
                                                </StackPanel>
                                                <TextBlock Text="Màu:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                                                <ComboBox x:Name="phaDoCtxColorBox" Width="110" Height="26"
                                                         IsEditable="True" IsTextSearchEnabled="False"
                                                         mah:ControlsHelper.CornerRadius="5"
                                                         VerticalContentAlignment="Center"
                                                         VerticalAlignment="Center" Margin="0,0,4,0"
                                                         SelectionChanged="PhaDoCtxColorBox_SelectionChanged"
                                                         KeyUp="PhaDoCtxColorBox_KeyUp"
                                                         ToolTip="Nhập mã màu (#RRGGBB) hoặc chọn trong danh sách"/>
                                                <Border x:Name="phaDoCtxColorPreview" Width="22" Height="22"
                                                        CornerRadius="4" Background="#595959"
                                                        BorderBrush="#CDD6E8" BorderThickness="1"
                                                        VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <ToggleButton x:Name="phaDoCtxBoldBtn" Content="B"
                                                              FontWeight="Bold" FontSize="13"
                                                              Width="30" Height="26"
                                                              mah:ControlsHelper.CornerRadius="5"
                                                              VerticalAlignment="Center"
                                                              ToolTip="Đậm / Thường"/>
                                            </StackPanel>

                                            <Rectangle Width="1" Fill="#CDD6E8" Margin="8,2" VerticalAlignment="Stretch"/>

                                            <!-- Nhóm SVG zones — active khi chọn title box hoặc ô gia đình -->
                                            <StackPanel x:Name="phaDoCtxSvgGroup" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Opacity="0.4">
                                                <TextBlock Text="Title Box" VerticalAlignment="Center" Margin="0,0,3,0" FontSize="11"/>
                                                <ComboBox x:Name="phaDoCtxTitleZoneCombo" Width="110" Height="26"
                                                          mah:ControlsHelper.CornerRadius="5" Margin="0,0,6,0"
                                                          DisplayMemberPath="Display" VerticalContentAlignment="Center"
                                                          SelectionChanged="PhaDoCtxTitleZoneCombo_SelectionChanged"
                                                          ToolTip="title_*.svg — khung/nền khối tiêu đề (khi chọn title box)"/>
                                                <TextBlock Text="Family Box" VerticalAlignment="Center" Margin="0,0,3,0" FontSize="11"/>
                                                <ComboBox x:Name="phaDoCtxFamilyBoxFrameCombo" Width="110" Height="26"
                                                          mah:ControlsHelper.CornerRadius="5" Margin="0,0,6,0"
                                                          DisplayMemberPath="Display" VerticalContentAlignment="Center"
                                                          SelectionChanged="PhaDoCtxFamilyBoxFrameCombo_SelectionChanged"
                                                          ToolTip="family_*.svg — khung/nền cả ô gia đình"/>
                                            </StackPanel>

                                            <Rectangle Width="1" Fill="#CDD6E8" Margin="8,2" VerticalAlignment="Stretch"/>

                                            <!-- Nút thao tác -->
                                            <Button x:Name="phaDoCtxApplyBtn" Content="Áp dụng"
                                                    Click="PhaDoCtxApply_Click"
                                                    mah:ControlsHelper.CornerRadius="7" Padding="8,3" Height="26"
                                                    VerticalAlignment="Center" Margin="0,0,4,0"
                                                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}"/>
                                            <Button Content="Cùng đời" Click="PhaDoCtxApplyAllGen_Click"
                                                    mah:ControlsHelper.CornerRadius="7" Padding="8,3" Height="26"
                                                    VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <Button Content="Tất cả phả" Click="PhaDoCtxApplyAllPha_Click"
                                                    mah:ControlsHelper.CornerRadius="7" Padding="8,3" Height="26"
                                                    VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Vùng vẽ phả đồ -->
                                    <ScrollViewer x:Name="phaDoScrollViewer" Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible"
                                                  PreviewMouseWheel="PhaDoScrollViewer_PreviewMouseWheel"
                                                  ToolTip="Kéo chuột trái trên vùng trống hoặc giữ nút giữa chuột để cuộn phả đồ">
                                        <Canvas x:Name="theCanvas" Background="AntiqueWhite"/>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                       

                        </TabItem>
                        <TabItem Header="5.Người">
                            <Grid Background="WhiteSmoke">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Margin="8,8,8,4" Padding="8" Background="AliceBlue" BorderBrush="#D8D8D8" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Button x:Name="personGridLoadButton"
                                                    Content="Danh sách"
                                                    Click="RefreshPersonGrid_Click"
                                                    Padding="10,2"
                                                    Margin="0,0,8,0"/>
                                            <CheckBox x:Name="personFullModeCheckBox"
                                                      Content="Tất cả người"
                                                      IsChecked="True"
                                                      Checked="PersonFullModeCheckChanged"
                                                      Unchecked="PersonFullModeCheckChanged"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <TextBlock Text="Tìm tên:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox x:Name="personSearchBox"
                                                     Width="280"
                                                     KeyDown="PersonSearch_KeyDown"
                                                     mah:TextBoxHelper.Watermark="Nhập tên rồi Enter — nhảy tới dòng"/>
                                            <Button Content="Dõ theo tên" Click="PersonSearch_Click" Padding="12,2" Margin="6,0,0,0"/>
                                            <Button Content="Xuất CSV" Click="ExportPersonGridToCsv_Click" Padding="12,2" Margin="8,0,0,0"
                                                    ToolTip="Xuất các dòng đang hiển thị (sau lọc) ra file CSV UTF-8"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          Margin="8,4,8,8"
                                          x:Name="personDataGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          SelectionUnit="FullRow"
                                          SelectionMode="Extended"
                                          ItemsSource="{Binding PersonGridView, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                          RowHeaderWidth="0"
                                          CanUserSortColumns="True"
                                          EnableRowVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          CellEditEnding="PersonDataGrid_CellEditEnding"
                                          SelectionChanged="PersonDataGrid_SelectionChanged"
                                          PreviewMouseRightButtonDown="PersonDataGrid_PreviewMouseRightButtonDown"
                                          LoadingRow="PersonDataGrid_LoadingRow">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Xuất CSV UTF-8..."
                                                      Click="ExportPersonGridToCsv_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Xem phả đồ nhỏ (từ đời cha)"
                                                      Click="PersonViewMiniPhaDo_Click"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Gia đình" Binding="{Binding FamilyGroupLabelForDisplay}" Width="220" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="ID" Binding="{Binding PersonId, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                        <DataGridTextColumn Header="Vai trò" Binding="{Binding RoleInFamily}" Width="70" IsReadOnly="True"/>
                                        <DataGridTemplateColumn Width="70">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Đời"/>
                                                    <TextBox x:Name="personGenFilterBox"
                                                             MinWidth="50"
                                                             Margin="0,2,0,0"
                                                             TextChanged="PersonFilter_TextChanged"
                                                             ToolTip="Lọc theo đời"/>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Generation}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Width="110">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Giới tính"/>
                                                    <ComboBox x:Name="personGenderFilterBox"
                                                              MinWidth="95"
                                                              Margin="0,2,0,0"
                                                              SelectionChanged="PersonGenderFilter_SelectionChanged">
                                                        <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                                                        <ComboBoxItem Content="Nam"/>
                                                        <ComboBoxItem Content="Nữ"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Gender}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox SelectedValue="{Binding Gender, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectedValuePath="Content">
                                                        <ComboBoxItem Content="Nam"/>
                                                        <ComboBoxItem Content="Nữ"/>
                                                    </ComboBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Width="200">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Tên người"/>
                                                    <TextBox x:Name="personNameFilterBox"
                                                             MinWidth="150"
                                                             Margin="0,2,0,0"
                                                             TextChanged="PersonFilter_TextChanged"
                                                             ToolTip="Lọc theo tên người"/>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding PersonName}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding PersonName, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Width="140">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Ngày sinh"/>
                                                    <TextBox x:Name="personDobFilterBox"
                                                             MinWidth="120"
                                                             Margin="0,2,0,0"
                                                             TextChanged="PersonFilter_TextChanged"
                                                             ToolTip="Lọc theo ngày sinh"/>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BirthDate}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Width="140">
                                            <DataGridTemplateColumn.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Ngày mất"/>
                                                    <TextBox x:Name="personDodFilterBox"
                                                             MinWidth="120"
                                                             Margin="0,2,0,0"
                                                             TextChanged="PersonFilter_TextChanged"
                                                             ToolTip="Lọc theo ngày mất"/>
                                                </StackPanel>
                                            </DataGridTemplateColumn.Header>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DeathDate}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding DeathDate, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Ở tại" Binding="{Binding Place, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                                        <DataGridTextColumn Header="Chi tiết" Binding="{Binding Detail, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </mah:MetroTabControl>
                </Grid>
            </mah:SplitView>
        </Grid>
        <!--BOTTOM STATUS BAR -->
        <StatusBar x:Name="mainStatusBar" Grid.Row="1">

            <StatusBarItem>
                <TextBlock Text="Liên hệ: Nghĩa (0908594239)"/>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock>
                        <Hyperlink NavigateUri="https://www.vietnamgiapha.com" RequestNavigate="Hyperlink_RequestNavigate">
                            Website Việt Nam Gia Phả
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock>           
                    <Hyperlink NavigateUri="https://www.facebook.com/groups/vietnamgiapha" RequestNavigate="Hyperlink_RequestNavigate">
                        Nhóm FB Việt Nam Gia Phả
                    </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock>           
                        <Hyperlink NavigateUri="https://www.vietnamgiapha" RequestNavigate="Hyperlink_RequestNavigate_1" >
                            <TextBlock Text="{Binding FamilyTree.GiaphaName}"/>
                            </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="File: "></TextBlock>
                    <TextBlock Text="{Binding FamilyTree.GP.FileName}"></TextBlock>
                    <TextBlock Text=" Lưu lần cuối lúc: "></TextBlock>
                    <TextBlock Text="{Binding FamilyTree.GP.FileNameUpdate}"></TextBlock>
                    <TextBlock Text="{Binding PhaDoSelectedBoxSizeText}" Margin="8,0,0,0"></TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
