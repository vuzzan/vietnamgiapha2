                                            </Button>
                                            <Button Height="10" Click="Button_Click_Delete_Person" ToolTip="Xóa 1 người ra khỏi gia đình hiện tại">
                                                <TextBlock Text="Xóa" />
                                            </Button>
                                        </StackPanel>
