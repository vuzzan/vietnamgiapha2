                                                    <TextBox Text="{Binding MANS_DETAIL}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Height="200" MaxLength="65534" FontSize="18" mah:ControlsHelper.CornerRadius="10"  />
