<mah:MetroWindow xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" 
        x:Class="vietnamgiapha.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controlzEx="urn:controlzex"
        xmlns:local="clr-namespace:vietnamgiapha"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:smith="clr-namespace:Smith.WPF.HtmlEditor;assembly=Smith.WPF.HtmlEditor"
        d:DataContext="{d:DesignInstance local:MainWindowViewModel}"
        Title="Việt Nam Gia Phả 2.2026 - www.vietnamgiapha.com từ năm 2003" 
        Width="1024"
        Height="768"
        MinWidth="800"
        MinHeight="600"
        Style="{DynamicResource VSWindowStyleKey}"
        Closing="MetroWindow_Closing"
        ResizeMode="CanResizeWithGrip"
        ShowIconOnTitleBar="True"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Initialized="MetroWindow_Initialized"
        Loaded="MetroWindow_Loaded"
        KeyDown="MainWindow_KeyDown"
        mc:Ignorable="d"
                 >

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- MahApps.Metro resource dictionaries. Make sure that all file names are Case Sensitive! -->
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <!-- Theme setting -->
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Orange.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ObjectDataProvider x:Key="SyncModePreferenceEnumValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type controlzEx:ThemeSyncMode}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="controlzEx:ThemeSyncMode" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>

            <Style x:Key="AppThemeMenuItemStyle"
                BasedOn="{StaticResource MahApps.Styles.MenuItem}"
                TargetType="{x:Type MenuItem}">
                <Setter Property="Command" Value="{Binding ChangeAccentCommand}" />
                <Setter Property="CommandParameter" Value="{Binding Name, Mode=OneWay}" />
                <Setter Property="Header" Value="{Binding Name, Mode=OneWay}" />
            </Style>

            <Style x:Key="AccentColorMenuItemStyle"
                   BasedOn="{StaticResource MahApps.Styles.MenuItem}"
                   TargetType="{x:Type MenuItem}">
                <Setter Property="Command" Value="{Binding ChangeAccentCommand}" />
                <Setter Property="CommandParameter" Value="{Binding Name, Mode=OneWay}" />
                <Setter Property="Header" Value="{Binding Name, Mode=OneWay}" />
            </Style>

            <!-- Hàng toolbox: icon tròn + chữ (chữ ẩn khi thu gọn; double-click thanh toolbox để bật/tắt) -->
            <Style x:Key="PhaDoToolboxRowStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="PhaDoToolboxCaptionStyle" TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="Margin" Value="6,0,2,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="NoWrap"/>
            </Style>
            <!-- Nút/icon toolbox Phả đồ: tròn, tooltip; double-click thanh toolbox để hiện chữ -->
            <Style x:Key="PhaDoToolboxIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="36"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RoundHost" Width="36" Height="36" CornerRadius="18"
                                    Background="#EDF2FA" BorderBrush="#B0BDD4" BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RoundHost" Property="Background" Value="#DCE6F5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="RoundHost" Property="Background" Value="#C5D4EB"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="RoundHost" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- ToggleButton mode toolbox: tròn, accent khi IsChecked=True (đang active) -->
            <Style x:Key="PhaDoToolboxToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="36"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="RoundHost" Width="36" Height="36" CornerRadius="18"
                                    Background="#EDF2FA" BorderBrush="#B0BDD4" BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Mode đang active: nền accent -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="RoundHost" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                    <Setter TargetName="RoundHost" Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RoundHost" Property="Background" Value="#DCE6F5"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="RoundHost" Property="Opacity" Value="0.85"/>
                                </MultiTrigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="RoundHost" Property="Background" Value="#C5D4EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PhaDoToolboxAccentRoundButtonStyle" TargetType="Button" BasedOn="{StaticResource PhaDoToolboxIconButtonStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RoundHost" Width="36" Height="36" CornerRadius="18"
                                    Background="{DynamicResource MahApps.Brushes.Accent}"
                                    BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                                    BorderThickness="1" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RoundHost" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="RoundHost" Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="PhaDoToolboxIconRadioStyle" TargetType="RadioButton">
                <Setter Property="Width" Value="36"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="RoundHost" Width="36" Height="36" CornerRadius="18"
                                    Background="#EDF2FA" BorderBrush="#B0BDD4" BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RoundHost" Property="Background" Value="#DCE6F5"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="RoundHost" Property="Background" Value="#C5D4EB"/>
                                    <Setter TargetName="RoundHost" Property="BorderBrush" Value="#7A94C4"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="RoundHost" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- ComboBox scope: chỉ icon khi đóng; dropdown vẫn hiện Label đầy đủ -->
            <!-- PhaDoScopeIconComboBoxStyle phải khai báo TRƯỚC PhaDoCardLayoutIconComboBoxStyle vì BasedOn dùng StaticResource -->
            <ControlTemplate x:Key="PhaDoScopeComboToggleTemplate" TargetType="ToggleButton">
                <Border Background="#EDF2FA" BorderBrush="#B0BDD4" BorderThickness="1"
                        Width="36" Height="36" CornerRadius="18" SnapsToDevicePixels="True">
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
            <Style x:Key="PhaDoScopeIconComboBoxStyle" TargetType="ComboBox">
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
                <Setter Property="MinWidth" Value="36"/>
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Focusable="False"
                                              ClickMode="Press"
                                              Template="{StaticResource PhaDoScopeComboToggleTemplate}"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide"
                                       IsOpen="{TemplateBinding IsDropDownOpen}">
                                    <Grid MinWidth="480"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border Background="White" BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="2"/>
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True" HorizontalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="ToolTip" Value="{Binding Label}"/>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>
            <ControlTemplate x:Key="PhaDoCardLayoutComboToggleTemplate" TargetType="ToggleButton">
                <Border Background="#EDF2FA" BorderBrush="#B0BDD4" BorderThickness="1"
                        Width="36" Height="36" CornerRadius="18" SnapsToDevicePixels="True">
                    <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
            <!-- BasedOn PhaDoScopeIconComboBoxStyle — phải đứng sau style cha -->
            <Style x:Key="PhaDoCardLayoutIconComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource PhaDoScopeIconComboBoxStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Focusable="False"
                                              ClickMode="Press"
                                              Template="{StaticResource PhaDoCardLayoutComboToggleTemplate}"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide"
                                       IsOpen="{TemplateBinding IsDropDownOpen}">
                                    <Grid MinWidth="160"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border Background="White" BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="2"/>
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Ellipse x:Key="AppThemeMenuIcon"
                 Width="16"
                 Height="16"
                 x:Shared="False"
                 Fill="{Binding ColorBrush, Mode=OneWay}"
                 Stroke="{Binding BorderColorBrush, Mode=OneWay}"
                 StrokeThickness="1" />
            <Ellipse x:Key="AccentMenuIcon"
                 Width="16"
                 Height="16"
                 x:Shared="False"
                 Fill="{Binding ColorBrush, Mode=OneWay}" />

            <Style x:Key="SyncModeMenuItemStyle"
               BasedOn="{StaticResource MahApps.Styles.MenuItem}"
               TargetType="{x:Type MenuItem}">
                <Setter Property="Command" Value="{Binding DataContext.ChangeSyncModeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                <Setter Property="CommandParameter" Value="{Binding Mode=OneTime}" />
                <Setter Property="Header" Value="{Binding Mode=OneTime}" />
            </Style>

            <!-- Menu chính (File, Settings, Update): icon nhỏ + chữ, padding thấp để vừa titlebar -->
            <Style x:Key="MainMenuTopLevelItemStyle"
                   TargetType="MenuItem"
                   BasedOn="{StaticResource MahApps.Styles.MenuItem}">
                <Setter Property="Padding" Value="8,3"/>
                <Setter Property="Margin" Value="2,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="TopLevelBorder"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    Padding="{TemplateBinding Padding}"
                                    VerticalAlignment="Center">
                                <Grid VerticalAlignment="Center">
                                    <ContentPresenter x:Name="HeaderHost"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center"/>
                                    <Popup x:Name="PART_Popup"
                                           Placement="Bottom"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade"
                                           IsOpen="{TemplateBinding IsSubmenuOpen}">
                                        <Border Background="{DynamicResource MahApps.Brushes.Control.Background}"
                                                BorderBrush="#CED8EA"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="4"
                                                Margin="0,4,0,0">
                                            <ScrollViewer CanContentScroll="True"
                                                          Style="{DynamicResource {ComponentResourceKey TypeInTargetAssembly={x:Type Menu}, ResourceId=MenuScrollViewer}}">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                                Grid.IsSharedSizeScope="True"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="TopLevelBorder" Property="Background" Value="#E3EBF7"/>
                                    <Setter TargetName="TopLevelBorder" Property="BorderBrush" Value="#B8C8E2"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen" Value="True">
                                    <Setter TargetName="TopLevelBorder" Property="Background" Value="#DCE6F5"/>
                                    <Setter TargetName="TopLevelBorder" Property="BorderBrush" Value="#A8BCE0"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style BasedOn="{StaticResource MahApps.Styles.MetroHeader}" TargetType="{x:Type mah:MetroHeader}">
                <Setter Property="HeaderTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical" UseLayoutRounding="True">
                                <TextBlock Margin="10 0" Text="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>


        </ResourceDictionary>
    </Window.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Menu Background="Transparent"
                  Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                  VerticalAlignment="Center">
                <MenuItem Style="{StaticResource MainMenuTopLevelItemStyle}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="File" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </MenuItem.Header>
                    <MenuItem Header="Mới" Command="{Binding OpenNewFileCommand}"/>
                    <Separator/>
                    <MenuItem Header="Mở File" Command="{Binding OpenFileCommand}"/>
                    <MenuItem Header="Lưu" Command="{Binding SaveFileCommand}"/>
                    <MenuItem Header="Lưu file khác...(Save As)" Command="{Binding SaveAsFileCommand}"/>
                    <!-- Tạm ẩn MessagePack — bật lại Visibility khi cần -->
                    <MenuItem Header="Lưu ra MessagePack..." Click="SaveAsMessagePack_Click" Visibility="Collapsed"/>
                    <MenuItem Header="Mở MessagePack..." Click="OpenMessagePack_Click" Visibility="Collapsed"/>
                    <Separator/>
                    <MenuItem Header="Quản lý kho SVG..." Click="OpenSvgLibraryManager_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Command="{Binding ExitAppCommand}"/>
                </MenuItem>
                <MenuItem Style="{StaticResource MainMenuTopLevelItemStyle}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Settings" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </MenuItem.Header>
                    <MenuItem Header="Cài đặt phả đồ..." Click="OpenSettingsDialog_Click"
                              ToolTip="Khoảng cách, kích thước ô, cỡ chữ — đơn vị cm (in)"/>
                </MenuItem>
                <MenuItem Style="{StaticResource MainMenuTopLevelItemStyle}"
                          Click="OpenHelpDialog_Click"
                          ToolTip="Hướng dẫn tạo, sửa gia phả và phím tắt">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Help" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Style="{StaticResource MainMenuTopLevelItemStyle}"
                          Click="Button_Click_3"
                          ToolTip="Kiểm tra và tải bản cập nhật phần mềm">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Update" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </Menu>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <!--<mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands ShowLastSeparator="False">
            <Button 
                Content="Help"
                ToolTip="Vào trang web vietnamgiapha.com để xem" />
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Popup chỉnh style nhãn "Đời X" — nằm trong Grid để hợp lệ, hiện khi click vào dải đời trên phả đồ -->
        <Popup x:Name="genLabelStylePopup"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               Placement="Mouse">
            <Border Background="{DynamicResource MahApps.Brushes.Control.Background}"
                    BorderBrush="#CED8EA" BorderThickness="1" CornerRadius="10"
                    Padding="14,12" MinWidth="260">
                <StackPanel>
                    <TextBlock x:Name="genLabelPopupTitle" Text="Nhãn Đời"
                               FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Cỡ chữ (pt):" VerticalAlignment="Center" Margin="0,0,10,6"/>
                        <TextBox x:Name="genLabelFontPtBox" Grid.Row="0" Grid.Column="1"
                                 Text="10" Width="70" HorizontalAlignment="Left"
                                 mah:ControlsHelper.CornerRadius="6" Margin="0,0,0,6"
                                 TextChanged="GenLabelFontPtBox_TextChanged"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Màu chữ (#hex):" VerticalAlignment="Center" Margin="0,0,10,6"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox x:Name="genLabelColorBox" Text="#595959"
                                     Width="100" mah:ControlsHelper.CornerRadius="6"
                                     TextChanged="GenLabelColorBox_TextChanged"/>
                            <Border x:Name="genLabelColorPreview" Width="24" Height="24"
                                    CornerRadius="4" Background="#595959"
                                    Margin="6,0,0,0" BorderBrush="#D0D8E8" BorderThickness="1"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Font:" VerticalAlignment="Center" Margin="0,0,10,6"/>
                        <TextBox x:Name="genLabelFontFamilyBox" Grid.Row="2" Grid.Column="1"
                                 Text="" mah:TextBoxHelper.Watermark="mặc định"
                                 mah:ControlsHelper.CornerRadius="6" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Kiểu:" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="genLabelBoldCheck" Content="Đậm" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <CheckBox x:Name="genLabelItalicCheck" Content="Nghiêng" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <Separator Margin="0,2,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Áp dụng tất cả" Click="GenLabelApplyAll_Click"
                                mah:ControlsHelper.CornerRadius="8" Padding="10,4"
                                Style="{StaticResource MahApps.Styles.Button.Square.Accent}"/>
                        <Button Content="Đặt lại mặc định" Click="GenLabelReset_Click"
                                mah:ControlsHelper.CornerRadius="8" Padding="10,4" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <Grid Grid.Row="0" Margin="0,0,0,0"  >
            <mah:SplitView 
            x:Name="SimpleSplitview" 
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="300"
            CanResizeOpenPane="True" 
            >
                <mah:SplitView.Pane>
                    <Grid x:Name="leftPaneRootGrid"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition x:Name="leftPaneLogRowDef" Height="200"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="leftPaneSearchPanel" Grid.Row="0" Background="#EEF3FA"
                                BorderBrush="#D0D8E8" BorderThickness="0,0,0,1"
